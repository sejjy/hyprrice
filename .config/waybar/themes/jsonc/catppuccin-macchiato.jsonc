      "(.*)Spotify": 
        "<span foreground='#a6da95'>пҶј </span> Spotify",
      "(.*)Spotify Premium": 
        "<span foreground='#a6da95'>пҶј </span> Spotify Premium",

      "OBS(.*)": 
        "<span foreground='#a5adcb'>у°»ғ </span> OBS Studio",

      "VLC media player": 
        "<span foreground='#f5a97f'>у°•ј </span> VLC Media Player",
      "(.*) - VLC media player": 
        "<span foreground='#f5a97f'>у°•ј </span> $1",

      "(.*) - mpv": 
        "<span foreground='#c6a0f6'>пҚ® </span> $1",

      "qView": "у°Ӣ©  qView",

      "(.*).jpg": "у°Ӣ©  $1.jpg",
      "(.*).png": "у°Ӣ©  $1.png",
      "(.*).svg": "у°Ӣ©  $1.svg",

