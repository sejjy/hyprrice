        "<span foreground='#8aadf4'>у°Ёһ </span> Visual Studio Code",

      "nvim": 
        "<span foreground='#a6da95'>оҡ® </span> Neovim",
      "nvim (.*)": 
        "<span foreground='#a6da95'>оҡ® </span> $1",

      "vim": 
        "<span foreground='#a6da95'>оҳ« </span> Vim",
